# ---- Mode ----
# development | test | production. Production refuses to start with dev-only
# defaults (e.g. the dev auth header) unless ALLOW_DEV_AUTH_IN_PROD=true is
# explicitly set (private-network deploys only — see DEPLOYMENT.md).
NODE_ENV=development
LOG_LEVEL=info
APP_VERSION=dev

# ---- API ----
API_PORT=4000
# Use a separate user/db per environment. The production URL is provisioned
# from the Bicep template in infra/ — never reuse dev credentials.
DATABASE_URL=postgresql://ces:ces@localhost:5432/ces_dev?schema=public

# ---- Microsoft Entra ID (Azure AD) — Batch 4 ----
# Get these from the App Registrations in your Entra tenant after the API and
# web apps are registered. Multi-tenant is OFF for CES Tech (single-tenant).
AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=
# Client secret for the API app registration — used by the Graph user-sync job
# (client-credentials). When blank, the sync falls back to a local mock directory.
AZURE_API_CLIENT_SECRET=
AZURE_API_AUDIENCE=api://ces-internal
# Auth mode: leave blank locally (resolves to the dev-header path). Set to
# `entra` to require real Microsoft JWTs (auto-on in prod with a real tenant).
AUTH_MODE=
# CSRF allowlist (prod): comma-separated browser origins permitted to make
# state-changing requests, e.g. https://ops.ces-pl.com
WEB_ORIGIN=

# ---- Web (Next.js) ----
NEXT_PUBLIC_AZURE_TENANT_ID=
NEXT_PUBLIC_AZURE_WEB_CLIENT_ID=
# Delegated API scope MSAL requests at login, e.g. api://ces-internal/access_as_user
NEXT_PUBLIC_AZURE_API_SCOPE=
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---- Mobile (Expo) ----
EXPO_PUBLIC_AZURE_TENANT_ID=
EXPO_PUBLIC_AZURE_MOBILE_CLIENT_ID=
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# ---- Azure Blob Storage (receipts) — Batch 4 ----
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=receipts
AZURE_STORAGE_CONNECTION_STRING=

# ---- Microsoft Graph (user sync, mail, Teams) — Batch 4 ----
# Cron schedule for the user/manager-chain sync job. Standard cron syntax.
GRAPH_SYNC_CRON=0 */6 * * *

# ---- Anthropic (AI flows) ----
# Required for the AI Onboarding Wizard to return real generations. When unset
# the API uses a deterministic mock so the flow stays demoable.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---- Dev auth stub ----
# DEV ONLY. In production these are ignored (the auth guard returns 401)
# unless ALLOW_DEV_AUTH_IN_PROD=true is explicitly set. ALLOW that ONLY when
# the API is locked behind an IP allowlist or VPN; never on a public URL.
DEV_AUTH_DEFAULT_EMAIL=admin@cestech.in
ALLOW_DEV_AUTH_IN_PROD=false

# ---- Operational ----
# Set false in CI/CD jobs that own the migration step separately; the API will
# then boot without running `prisma migrate deploy`.
RUN_MIGRATIONS=true
