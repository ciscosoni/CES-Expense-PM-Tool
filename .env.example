# ---- API ----
NODE_ENV=development
API_PORT=4000
DATABASE_URL=postgresql://ces:ces@localhost:5432/ces_dev?schema=public

# ---- Microsoft Entra ID (Azure AD) ----
# Get these from the App Registration in your Entra tenant.
AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=
AZURE_API_CLIENT_SECRET=
# Comma-separated scopes the API accepts
AZURE_API_AUDIENCE=api://ces-internal

# ---- Web (Next.js) ----
NEXT_PUBLIC_AZURE_TENANT_ID=
NEXT_PUBLIC_AZURE_WEB_CLIENT_ID=
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---- Mobile (Expo) ----
EXPO_PUBLIC_AZURE_TENANT_ID=
EXPO_PUBLIC_AZURE_MOBILE_CLIENT_ID=
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# ---- Azure Blob Storage (receipts) ----
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=receipts
AZURE_STORAGE_CONNECTION_STRING=

# ---- Microsoft Graph (user sync, mail, Teams) ----
GRAPH_SYNC_CRON=0 */6 * * *
