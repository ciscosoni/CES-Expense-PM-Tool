{
  "name": "@ces/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "echo 'Mobile builds run via EAS; see https://docs.expo.dev/eas/' && exit 0",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
