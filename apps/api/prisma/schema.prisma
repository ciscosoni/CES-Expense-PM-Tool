// CES Tech internal tool — Prisma schema
// The schema follows the Zod source-of-truth in `packages/domain`. Keep them in sync.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity & RBAC ----------

model User {
  id            String       @id @default(uuid()) @db.Uuid
  azureOid      String       @unique
  email         String       @unique
  displayName   String
  jobTitle      String?
  department    String?
  managerId     String?      @db.Uuid
  manager       User?        @relation("Manager", fields: [managerId], references: [id])
  reports       User[]       @relation("Manager")
  gradeId       String?      @db.Uuid
  grade         Grade?       @relation(fields: [gradeId], references: [id])
  roles         UserRole[]
  active        Boolean      @default(true)
  assignedTasks    Task[]          @relation("TaskAssignee")
  timeLogs         TimeLog[]
  allocations      Allocation[]
  managedProjects  Project[]       @relation("ProjectPM")
  ownedProjects    Project[]       @relation("ProjectOwner")
  travelRequests   TravelRequest[] @relation("TravelRequester")
  approvedTravels  TravelRequest[] @relation("TravelApprover")
  expenses              Expense[]       @relation("ExpenseUser")
  approvedExpenses      Expense[]       @relation("ExpenseApprover")
  ownerApprovedExpenses Expense[]       @relation("ExpenseOwnerApprover")
  rejectedExpenses      Expense[]       @relation("ExpenseRejector")
  reimbursements        Reimbursement[] @relation("ReimbursementUser")
  attendanceEvents          AttendanceEvent[]          @relation("AttendanceEventUser")
  attendanceDays            AttendanceDay[]            @relation("AttendanceDayUser")
  attendanceRegularizations AttendanceRegularization[] @relation("AttendanceRegUser")
  decidedRegularizations    AttendanceRegularization[] @relation("AttendanceRegApprover")
  authoredComments          Comment[]                  @relation("CommentAuthor")
  createdChangeRequests     ChangeRequest[]            @relation("ChangeRequestCreator")
  decidedChangeRequests     ChangeRequest[]            @relation("ChangeRequestApprover")
  notifications             Notification[]             @relation("UserNotifications")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
}

enum UserRole {
  ADMIN
  FINANCE
  PROJECT_OWNER
  PROJECT_MANAGER
  APPROVER
  ENGINEER
}

// ---------- Grades & cost rates (time-versioned) ----------

model Grade {
  id              String     @id @default(uuid()) @db.Uuid
  code            String     @unique
  name            String
  seniorityOrder  Int
  active          Boolean    @default(true)
  users           User[]
  costRates       CostRate[]
  entitlementRows EntitlementMatrixRow[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
}

model CostRate {
  id            String   @id @default(uuid()) @db.Uuid
  gradeId       String   @db.Uuid
  grade         Grade    @relation(fields: [gradeId], references: [id])
  ratePerDay    Decimal  @db.Decimal(14, 4)
  currency      String   @db.Char(3)
  effectiveFrom DateTime @db.Date

  @@index([gradeId, effectiveFrom])
}

// ---------- Cities & entitlement matrix ----------

enum CityTier {
  METRO
  TIER_2
  TIER_3
  INTERNATIONAL
}

model City {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  state           String?
  country         String          @default("IN")
  tier            CityTier
  active          Boolean         @default(true)
  projectSites    ProjectSite[]
  travelFromHere  TravelRequest[] @relation("TravelFromCity")
  travelToHere    TravelRequest[] @relation("TravelToCity")

  @@unique([name, country])
}

enum TravelClass {
  FLIGHT_ECONOMY
  FLIGHT_BUSINESS
  TRAIN_3AC
  TRAIN_2AC
  TRAIN_1AC
  BUS_AC
  TAXI
}

model EntitlementMatrixRow {
  id                          String      @id @default(uuid()) @db.Uuid
  gradeId                     String      @db.Uuid
  grade                       Grade       @relation(fields: [gradeId], references: [id])
  cityTier                    CityTier
  perDiemAmount               Decimal     @db.Decimal(14, 4)
  perDiemCurrency             String      @db.Char(3)
  lodgingCapPerNight          Decimal     @db.Decimal(14, 4)
  lodgingCurrency             String      @db.Char(3)
  travelClass                 TravelClass
  localConveyanceCapPerDay    Decimal     @db.Decimal(14, 4)
  localConveyanceCurrency     String      @db.Char(3)
  effectiveFrom               DateTime    @db.Date

  @@index([gradeId, cityTier, effectiveFrom])
}

model DaPolicy {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String
  partialDayPercent     Decimal  @db.Decimal(5, 4)
  intraCitySameDayPaysDa Boolean
  effectiveFrom         DateTime @db.Date
}

// ---------- Clients & projects ----------

enum ClientKind {
  SI
  OEM
}

model Client {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @unique
  kind      ClientKind
  active    Boolean    @default(true)
  projects  Project[]
}

model EndCustomer {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @unique
  industry String?
  active   Boolean   @default(true)
  projects Project[]
}

enum ProjectCategory {
  ACI
  NON_ACI
  SD_WAN
  SECURITY
  AUDIT
  MANAGED_SERVICES
}

enum BillingModel {
  FIXED_PRICE
  T_AND_M
  MILESTONE
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  CLOSED
  CANCELLED
}

model Project {
  id                   String          @id @default(uuid()) @db.Uuid
  code                 String          @unique
  name                 String
  clientId             String          @db.Uuid
  client               Client          @relation(fields: [clientId], references: [id])
  endCustomerId        String?         @db.Uuid
  endCustomer          EndCustomer?    @relation(fields: [endCustomerId], references: [id])
  whiteLabel           Boolean         @default(false)
  category             ProjectCategory
  billingModel         BillingModel
  contractValue        Decimal         @db.Decimal(18, 4)
  contractCurrency     String          @db.Char(3)
  // Reserved for v2 hardware/OEM pass-through; v1 is services-only.
  includesPassthrough  Boolean         @default(false)
  pmId                 String          @db.Uuid
  pm                   User            @relation("ProjectPM", fields: [pmId], references: [id])
  /// Project owner — has budget authority and 1st-level approval on expenses.
  /// Per CLAUDE.md role model added in Slice 2B (2026-05-28 redesign).
  ownerId              String?         @db.Uuid
  owner                User?           @relation("ProjectOwner", fields: [ownerId], references: [id])
  /// Total project budget set by the Owner. Distinct from contractValue
  /// (contract is what we bill the client; budget is the cap the Owner manages
  /// for internal spend like travel + expenses).
  budget               Decimal?        @db.Decimal(18, 4)
  budgetCurrency       String?         @db.Char(3)
  plannedStart         DateTime        @db.Date
  plannedEnd           DateTime        @db.Date
  status               ProjectStatus
  sites                ProjectSite[]
  milestones           Milestone[]
  tasks                Task[]
  allocations          Allocation[]
  travelRequests       TravelRequest[]
  expenses             Expense[]
  attendanceRegularizations AttendanceRegularization[]
  changeRequests       ChangeRequest[]
  baseline             ProjectBaseline?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?
}

model ProjectSite {
  id               String            @id @default(uuid()) @db.Uuid
  projectId        String            @db.Uuid
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteName         String
  cityId           String            @db.Uuid
  city             City              @relation(fields: [cityId], references: [id])
  address          String?
  geofences        Geofence[]
  attendanceEvents AttendanceEvent[]
}

/// Geofence around a project site. Mobile attendance check-in compares
/// device GPS against these zones — feeds the AttendanceEvent stream.
model Geofence {
  id            String      @id @default(uuid()) @db.Uuid
  projectSiteId String      @db.Uuid
  projectSite   ProjectSite @relation(fields: [projectSiteId], references: [id], onDelete: Cascade)
  centerLat     Decimal     @db.Decimal(9, 6)
  centerLng     Decimal     @db.Decimal(9, 6)
  radiusMeters  Int
}

model Milestone {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  value         Decimal   @db.Decimal(18, 4)
  currency      String    @db.Char(3)
  plannedDate   DateTime  @db.Date
  signedOffDate DateTime? @db.Date
}

// ---------- Tasks & time tracking ----------

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

model Task {
  id              String     @id @default(uuid()) @db.Uuid
  projectId       String     @db.Uuid
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId        String?    @db.Uuid
  parent          Task?      @relation("TaskTree", fields: [parentId], references: [id])
  children        Task[]     @relation("TaskTree")
  name            String
  description     String?
  assigneeId      String?    @db.Uuid
  assignee        User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  status          TaskStatus @default(TODO)
  percentComplete Int        @default(0)
  plannedStart    DateTime?  @db.Date
  plannedEnd      DateTime?  @db.Date
  actualStart     DateTime?  @db.Date
  actualEnd       DateTime?  @db.Date
  timeLogs        TimeLog[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  @@index([projectId])
  @@index([assigneeId])
}

model TimeLog {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date
  hours     Decimal  @db.Decimal(5, 2)
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([taskId, date])
}

model Allocation {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  user              User     @relation(fields: [userId], references: [id])
  projectId         String   @db.Uuid
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Percent allocation as integer 0..100.
  percentAllocation Int
  periodStart       DateTime @db.Date
  periodEnd         DateTime @db.Date
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, periodStart, periodEnd])
  @@index([projectId])
}

// ---------- Travel & trips ----------

enum TripType {
  INTER_CITY
  INTRA_CITY
}

enum TravelStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

model TravelRequest {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  user            User         @relation("TravelRequester", fields: [userId], references: [id])
  projectId       String       @db.Uuid
  project         Project      @relation(fields: [projectId], references: [id])
  fromCityId      String       @db.Uuid
  fromCity        City         @relation("TravelFromCity", fields: [fromCityId], references: [id])
  toCityId        String       @db.Uuid
  toCity          City         @relation("TravelToCity", fields: [toCityId], references: [id])
  startDate       DateTime     @db.Date
  endDate         DateTime     @db.Date
  travelClass     TravelClass
  tripType        TripType
  purpose         String
  status          TravelStatus @default(DRAFT)
  approverId      String?      @db.Uuid
  approver        User?        @relation("TravelApprover", fields: [approverId], references: [id])
  approvedAt      DateTime?
  rejectReason    String?
  trip            Trip?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([userId, status])
  @@index([projectId, status])
}

model Trip {
  id                       String         @id @default(uuid()) @db.Uuid
  travelRequestId          String         @unique @db.Uuid
  travelRequest            TravelRequest  @relation(fields: [travelRequestId], references: [id])
  actualStart              DateTime
  actualEnd                DateTime?
  /// Stringified JSON: a list of [lat,lng,ts] samples; cheap for v1.
  gpsTrail                 Json?
  /// Frozen on trip close from @ces/da-engine
  daEligibleDays           Decimal?       @db.Decimal(6, 2)
  daAmount                 Decimal?       @db.Decimal(14, 4)
  daCurrency               String?        @db.Char(3)
  /// Frozen breakdown for "tap to see derivation" per Principle #3
  daBreakdown              Json?
  travelActualCost         Decimal        @default(0) @db.Decimal(14, 4)
  lodgingActualCost        Decimal        @default(0) @db.Decimal(14, 4)
  localConveyanceActualCost Decimal       @default(0) @db.Decimal(14, 4)
  expenses                 Expense[]
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

// ---------- Expenses & reimbursements ----------

enum ExpenseCategory {
  TRAVEL
  LODGING
  MEALS
  LOCAL_CONVEYANCE
  COMMUNICATION
  MATERIALS
  OTHER
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  /// Project Owner's first-level approval. Cleared when Finance approves.
  OWNER_APPROVED
  /// Finance approved — ready to be batched into a Reimbursement.
  APPROVED
  REJECTED
  REIMBURSED
}

model Expense {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @db.Uuid
  user            User            @relation("ExpenseUser", fields: [userId], references: [id])
  projectId       String          @db.Uuid
  project         Project         @relation(fields: [projectId], references: [id])
  tripId          String?         @db.Uuid
  trip            Trip?           @relation(fields: [tripId], references: [id])
  category        ExpenseCategory
  amount          Decimal         @db.Decimal(14, 4)
  currency        String          @db.Char(3)
  incurredOn      DateTime        @db.Date
  /// Placeholder for receipt file URL; full Receipt entity with EXIF/pHash/OCR
  /// lands in Slice 1C-γ.
  receiptUrl      String?
  notes           String?
  status          ExpenseStatus   @default(DRAFT)
  /// Owner who gave first-level (budget) approval.
  ownerApproverId String?         @db.Uuid
  ownerApprover   User?           @relation("ExpenseOwnerApprover", fields: [ownerApproverId], references: [id])
  ownerApprovedAt DateTime?
  /// Finance approver who gave final approval (last person to act).
  approverId      String?         @db.Uuid
  approver        User?           @relation("ExpenseApprover", fields: [approverId], references: [id])
  approvedAt      DateTime?
  rejectReason    String?
  rejectedById    String?         @db.Uuid
  rejectedBy      User?           @relation("ExpenseRejector", fields: [rejectedById], references: [id])
  reimbursementId String?         @db.Uuid
  reimbursement   Reimbursement?  @relation(fields: [reimbursementId], references: [id])
  receipts        Receipt[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([userId, status])
  @@index([projectId, status])
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model Reimbursement {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  user        User                @relation("ReimbursementUser", fields: [userId], references: [id])
  totalAmount Decimal             @db.Decimal(14, 4)
  currency    String              @db.Char(3)
  status      ReimbursementStatus @default(PENDING)
  paidOn      DateTime?           @db.Date
  reference   String?
  expenses    Expense[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId, status])
}

// ---------- Receipts (with fraud-detection flags) ----------

enum ReceiptFlagKind {
  DUPLICATE_HASH
  AMOUNT_OCR_MISMATCH
  DATE_OUT_OF_TRIP
  GPS_FAR_FROM_TRIP
  SUSPICIOUS_VENDOR
  NO_EXIF
}

enum ReceiptFlagSeverity {
  INFO
  WARN
  BLOCK
}

model Receipt {
  id             String        @id @default(uuid()) @db.Uuid
  expenseId      String        @db.Uuid
  expense        Expense       @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileUrl        String
  contentType    String
  /// SHA-256 hex of the raw bytes — exact dup detection.
  contentHash    String        @db.Char(64)
  /// 64-bit perceptual hash (hex) for near-duplicate detection.
  perceptualHash String?       @db.Char(16)
  exifTimestamp  DateTime?
  exifLat        Decimal?      @db.Decimal(9, 6)
  exifLng        Decimal?      @db.Decimal(9, 6)
  /// OCR'd vendor + amount + date (JSON). Stored verbatim for audit.
  ocrJson        Json?
  ocrAmount      Decimal?      @db.Decimal(14, 4)
  flags          ReceiptFlag[]
  createdAt      DateTime      @default(now())

  @@index([expenseId])
  @@index([contentHash])
  @@index([perceptualHash])
}

model ReceiptFlag {
  id        String              @id @default(uuid()) @db.Uuid
  receiptId String              @db.Uuid
  receipt   Receipt             @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  kind      ReceiptFlagKind
  severity  ReceiptFlagSeverity
  detail    String?
  createdAt DateTime            @default(now())

  @@index([receiptId])
  @@index([kind])
}

// ---------- Attendance (Slice 2C) ----------

/// Raw mobile-emitted events. Daily summary (AttendanceDay) is derived.
/// Per CLAUDE.md §10: source of truth for "was the engineer actually on site?"
/// — defuses the manager-vs-engineer pain point.
enum AttendanceEventKind {
  CHECK_IN
  CHECK_OUT
  GEOFENCE_ENTER
  GEOFENCE_EXIT
  MANUAL_ENTRY
}

enum AttendanceEventSource {
  MOBILE
  WEB
  MANUAL
  SYSTEM
}

model AttendanceEvent {
  id              String                @id @default(uuid()) @db.Uuid
  userId          String                @db.Uuid
  user            User                  @relation("AttendanceEventUser", fields: [userId], references: [id])
  kind            AttendanceEventKind
  occurredAt      DateTime
  lat             Decimal?              @db.Decimal(9, 6)
  lng             Decimal?              @db.Decimal(9, 6)
  accuracyMeters  Int?
  /// Site whose geofence the device was inside at the time of the event. NULL
  /// when the event happened off-site (REMOTE work) or for MANUAL_ENTRY.
  projectSiteId   String?               @db.Uuid
  projectSite     ProjectSite?          @relation(fields: [projectSiteId], references: [id])
  source          AttendanceEventSource @default(MOBILE)
  createdAt       DateTime              @default(now())

  @@index([userId, occurredAt])
  @@index([projectSiteId, occurredAt])
}

enum AttendanceDayStatus {
  ABSENT
  REMOTE
  ON_SITE
  PARTIAL
  REGULARIZED
}

/// Persisted derivation of a user's day so queries (calendar, KPIs) are cheap.
/// Recomputed on event ingest + on regularization approval. The derivation
/// reasoning is stored in `notes` so the engineer can see why the system
/// marked their day the way it did (Principle #3).
model AttendanceDay {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @db.Uuid
  user            User                @relation("AttendanceDayUser", fields: [userId], references: [id])
  date            DateTime            @db.Date
  firstEventAt    DateTime?
  lastEventAt     DateTime?
  /// Minutes the user was inside any project site geofence during this day.
  onSiteMinutes   Int                 @default(0)
  /// JSON array of ProjectSite IDs the user touched today.
  projectSiteIds  Json                @default("[]")
  status          AttendanceDayStatus @default(ABSENT)
  eventCount      Int                 @default(0)
  /// Plain-English derivation log, e.g. "ON_SITE: 5h 23m inside SBI-Mumbai-DC geofence".
  derivationNote  String?
  /// When a regularization decision flips this day's effective status.
  regularizationId String?            @unique @db.Uuid
  regularization   AttendanceRegularization? @relation("DayRegularization", fields: [regularizationId], references: [id])
  recomputedAt    DateTime            @default(now())

  @@unique([userId, date])
  @@index([date, status])
}

enum RegularizationReason {
  REMOTE_WORK
  MISSED_PUNCH
  SITE_VISIT_NOT_GEOFENCED
  SICK
  PERSONAL
  OTHER
}

enum RegularizationStatus {
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

/// Engineer-submitted ask to override the system's derived status for a day.
/// Required because GPS/geofence is imperfect — site GPS may be off, customer
/// site may have no geofence configured yet, engineer may have been at a
/// supporting location (e.g. spares pickup). Approval lives with the
/// engineer's reporting manager OR the project owner.
model AttendanceRegularization {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @db.Uuid
  user          User                 @relation("AttendanceRegUser", fields: [userId], references: [id])
  date          DateTime             @db.Date
  reason        RegularizationReason
  /// Free-text justification. Required when reason = OTHER; recommended otherwise.
  notes         String
  /// Optional — pin the day to a project (helps PM context + drives DA/P&L if claimed as billable).
  projectId     String?              @db.Uuid
  project       Project?             @relation(fields: [projectId], references: [id])
  status        RegularizationStatus @default(SUBMITTED)
  approverId    String?              @db.Uuid
  approver      User?                @relation("AttendanceRegApprover", fields: [approverId], references: [id])
  decidedAt     DateTime?
  rejectReason  String?
  day           AttendanceDay?       @relation("DayRegularization")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?

  @@index([userId, date])
  @@index([status])
}

// ---------- Project Change Requests (Slice 2D) ----------

/// Frozen at first project save. Baseline-vs-current drives "scope creep
/// without P&L visibility" detection (pain point #2). Changes happen via
/// approved ChangeRequest rows, never by directly editing the project.
model ProjectBaseline {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @unique @db.Uuid
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractValue     Decimal  @db.Decimal(18, 4)
  contractCurrency  String   @db.Char(3)
  budget            Decimal? @db.Decimal(18, 4)
  budgetCurrency    String?  @db.Char(3)
  plannedStart      DateTime @db.Date
  plannedEnd        DateTime @db.Date
  scopeSummary      String?
  snapshotAt        DateTime @default(now())
  /// Frozen milestone list at baseline time. JSON: [{name,value,currency,plannedDate}].
  milestonesJson    Json     @default("[]")
}

enum ChangeRequestType {
  SCOPE
  TIME
  COST
  MIXED
}

enum ChangeRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  WITHDRAWN
}

model ChangeRequest {
  id                String              @id @default(uuid()) @db.Uuid
  projectId         String              @db.Uuid
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Auto-numbered per project: CR-001, CR-002, … (assigned on first save).
  code              String
  title             String
  type              ChangeRequestType
  reason            String
  /// Numeric deltas to the project — applied on approval, stored as signed values.
  /// Either or both of cost and time may be present; UI shows whichever is non-null.
  contractValueDelta Decimal?           @db.Decimal(18, 4)
  budgetDelta        Decimal?           @db.Decimal(18, 4)
  /// Days added to plannedEnd (positive = slip, negative = pull-in).
  daysDelta          Int?
  /// Optional scope-text delta — what's being added/removed.
  scopeDelta         String?
  status             ChangeRequestStatus @default(DRAFT)
  createdById        String              @db.Uuid
  createdBy          User                @relation("ChangeRequestCreator", fields: [createdById], references: [id])
  approverId         String?             @db.Uuid
  approver           User?               @relation("ChangeRequestApprover", fields: [approverId], references: [id])
  submittedAt        DateTime?
  decidedAt          DateTime?
  rejectReason       String?
  /// Snapshot of the project's contract/budget/plannedEnd at the moment of
  /// approval — so the "current" view can be reconstructed even if more CRs
  /// come in after this one.
  appliedSnapshot    Json?
  comments           Comment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@unique([projectId, code])
  @@index([projectId, status])
}

// ---------- Polymorphic comments (Slice 2E) ----------

/// Threaded comments attachable to any entity. `entityKind` is a string label
/// (PROJECT, TASK, EXPENSE, TRIP, CHANGE_REQUEST, …) rather than a hard FK
/// because the trade-off favors flexibility for v1. Soft-delete preserves
/// thread structure when a parent comment is removed.
model Comment {
  id              String         @id @default(uuid()) @db.Uuid
  entityKind      String
  entityId        String         @db.Uuid
  authorId        String         @db.Uuid
  author          User           @relation("CommentAuthor", fields: [authorId], references: [id])
  body            String
  parentId        String?        @db.Uuid
  parent          Comment?       @relation("CommentTree", fields: [parentId], references: [id])
  replies         Comment[]      @relation("CommentTree")
  /// If this comment lives on a ChangeRequest, set the FK so cascade delete
  /// of the CR cleans up its thread. Other entity kinds use entityKind+entityId only.
  changeRequestId String?        @db.Uuid
  changeRequest   ChangeRequest? @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  @@index([entityKind, entityId, createdAt])
}

// ---------- Anomaly detection (Slice 2E) ----------

enum AnomalyKind {
  RECEIPT_DUPLICATE
  RECEIPT_AMOUNT_MISMATCH
  RECEIPT_DATE_OUT_OF_TRIP
  RECEIPT_GPS_FAR
  ALLOCATION_OVERBOOK
  PROJECT_OVER_BUDGET
  PROJECT_MARGIN_RED
  EXPENSE_OVER_CAP
  ATTENDANCE_NO_PUNCH
  ATTENDANCE_REGULARIZATION_STALE
}

enum AnomalySeverity {
  INFO
  WARN
  CRITICAL
}

/// Admin-tunable rules. The detector runs them on demand (anomalies endpoint)
/// + idempotently writes Anomaly rows. Disabling a rule short-circuits the
/// detector without losing history.
model AnomalyRule {
  id          String          @id @default(uuid()) @db.Uuid
  kind        AnomalyKind     @unique
  name        String
  description String
  severity    AnomalySeverity
  /// JSON config — shape depends on `kind`. e.g. for PROJECT_MARGIN_RED:
  /// `{ "marginPercentBelow": 10 }`. Surfaced to admins so the threshold is
  /// editable from /admin/anomaly-rules.
  config      Json            @default("{}")
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

/// One row per detection. Surfaces in the leadership dashboard's anomalies
/// feed. `resolvedAt`/`resolvedById` flips when an admin/leader acknowledges
/// the finding — closed anomalies stay in the audit trail.
model Anomaly {
  id            String          @id @default(uuid()) @db.Uuid
  kind          AnomalyKind
  severity      AnomalySeverity
  /// Polymorphic pointer to the offending row (EXPENSE/PROJECT/USER/RECEIPT/…).
  entityKind    String
  entityId      String          @db.Uuid
  /// Stable de-dupe key so the detector can run repeatedly without spam.
  /// Format suggestion: "<kind>:<entityId>[:<bucket>]".
  fingerprint   String          @unique
  detail        String?
  /// Cached extra info for the dashboard (e.g. user + project names + amount)
  /// so the UI doesn't have to refetch joins per row.
  context       Json?
  detectedAt    DateTime        @default(now())
  resolvedAt    DateTime?
  resolvedById  String?         @db.Uuid
  resolutionNote String?

  @@index([kind, severity, detectedAt])
  @@index([entityKind, entityId])
}

// ---------- Auto-approval policy (P6 — suggest-only) ----------

/// Admin-editable policy that defines which expenses are "clean" enough to be
/// surfaced for one-click approval. Suggest-only: the agent never approves on
/// its own. A single active row (no hardcoded amounts in code — non-negotiable #1).
model AutoApprovalPolicy {
  id             String   @id @default(uuid()) @db.Uuid
  /// When false, no auto-approvable suggestions are surfaced.
  enabled        Boolean  @default(true)
  /// Max expense amount eligible (compared in the same currency).
  maxAmount      Decimal  @db.Decimal(14, 4)
  currency       String   @default("INR") @db.Char(3)
  /// Require at least one attached receipt.
  requireReceipt Boolean  @default(true)
  /// Require no WARN/BLOCK receipt fraud flags (covers GPS/dup/amount/date).
  requireNoFlags Boolean  @default(true)
  updatedById    String?  @db.Uuid
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// ---------- Audit log (soft-delete + history) ----------

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  entity    String
  entityId  String   @db.Uuid
  action    String
  actorId   String?  @db.Uuid
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId, createdAt])
}

// ---------- Notifications (Phase 3 — Automation Heartbeat) ----------

/// In-app notification record. Also the audit trail of what was delivered to
/// which channel. Emitted by domain events (approvals, reimbursements) and the
/// scheduler (anomaly sweeps). Delivery to Teams/email is layered on top.
model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  kind       String
  title      String
  body       String?
  severity   String   @default("INFO") // INFO | WARN | CRITICAL
  /// Polymorphic deep-link target + the web route to open it.
  entityKind String?
  entityId   String?  @db.Uuid
  linkPath   String?
  /// Comma-separated channels the notification was delivered to (IN_APP,TEAMS,EMAIL).
  channels   String   @default("IN_APP")
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}
